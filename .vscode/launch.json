{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug mtgsim: single game",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/cmd/mtgsim",
      "cwd": "${workspaceFolder}",
      "args": [
        "-games=100",
        "-decks=decks/1v1",
        "-swap=0",
        "-v=2",
        "-log=META"
      ],
      "console": "integratedTerminal"
    },
 {
      "name": "Debug download_edh_decks.py",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/download_edh_decks.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "env": {
        "TOPDECK_API_KEY": "API_KEY"
      },
      "args": [
        "--days",
        "30",
        "--min-participants",
        "20",
        "--verbose"
      ],
      "justMyCode": true
    },
  ]
}


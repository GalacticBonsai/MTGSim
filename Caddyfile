#   api.h7lla.com {
#       tls {
#           dns cloudflare YOUR_API_TOKEN
#       }
#       reverse_proxy api:8080
#   }
#
# Or open ports on the LXC and switch to:
#   api.h7lla.com { reverse_proxy api:8080 }
